{
  "name": "co-pivot",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:web\" \"bun run dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:1420 && electron .",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "start": "electron .",
    "dist": "bun run build && electron-builder --mac",
    "dist:dir": "bun run build && electron-builder --mac dir",
    "dist:dmg": "bun run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "@mantine/core": "^8.1.2",
    "@mantine/hooks": "^8.1.2",
    "@tabler/icons-react": "^3.31.0",
    "js-yaml": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "^35.2.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.aiheon.copivot",
    "productName": "co-pivot",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/mac/icon.icns"
    }
  },
  "packageManager": "bun@1.3.11",
  "description": "Local-first desktop app for browsing and resuming GitHub Copilot CLI sessions",
  "author": "aiheon"
}
